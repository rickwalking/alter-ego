{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Mutation testing runs a subset of the codebase — hooks + critical components that silent coverage would miss. Keep the `mutate` globs narrow: full-repo mutation runs are ~10min+ and the signal-to-noise drops fast on pure UI.",
  "packageManager": "npm",
  "testRunner": "vitest",
  "testRunner_comment": "Stryker runs `vitest --run` for each mutant; the vitest-runner plugin handles that.",
  "vitest": {
    "configFile": "vitest.stryker.config.ts"
  },
  "vitest_comment": "A Stryker-only vitest config that drops babel-plugin-react-compiler. The compiler and Stryker's instrumenter both rewrite the AST and produced duplicated `stryNS_9fa48` declarations that broke parsing.",
  "disableTypeChecks": false,
  "reporters": ["clear-text", "progress", "html"],
  "htmlReporter": {
    "fileName": "reports/mutation/mutation.html"
  },
  "coverageAnalysis": "off",
  "mutate": [
    "src/lib/api-client.ts",
    "src/features/carousel/queries.ts",
    "src/features/chat/queries.ts",
    "src/features/create/hooks/use-carousel.ts",
    "src/features/create/hooks/use-editorial-workflow.ts",
    "src/features/create/hooks/use-editorial-workflow-utils.ts",
    "src/features/create/hooks/use-editorial-workflow-resume.ts",
    "src/features/create/hooks/use-editorial-workflow-sse.ts",
    "src/lib/client-api-url.ts",
    "src/features/chat/hooks/use-chat.ts",
    "src/features/knowledge/queries.ts",
    "src/features/knowledge/hooks/use-documents.ts",
    "src/features/publish/hooks/use-publish-chat.ts",
    "src/components/atoms/neon-button.tsx",
    "src/components/atoms/neon-badge.tsx",
    "src/components/molecules/neon-card.tsx",
    "src/features/create/components/image-prompt-review.tsx",
    "src/features/dashboard/workflow/adapters/workflow-adapter.ts",
    "src/features/knowledge/adapters/document-adapter.ts",
    "src/features/blog/adapters/blog-post-adapter.ts"
  ],
  "mutate_comment": "Scoped to .ts hook/query modules. Editorial workflow split hooks are mutation-gated alongside unit tests in matching *.test.ts files.",
  "thresholds": {
    "high": 65,
    "low": 50,
    "break": 30
  },
  "thresholds_comment": "ADR-005 UI component gates: break 30%, low 50%, high 65%. Hook modules in mutate globs may score higher.",
  "timeoutMS": 60000,
  "concurrency": 4,
  "ignorePatterns": [
    "node_modules",
    ".next",
    "tests/e2e",
    "reports",
    "coverage",
    ".stryker-tmp",
    "src/features/knowledge/components/document-form.test.tsx",
    "src/features/knowledge/components/document-list.test.tsx",
    "src/features/knowledge/components/knowledge-base-interface.test.tsx",
    "src/features/dashboard/workflow/adapters/workflow-adapter.test.ts",
    "src/features/dashboard/calendar/adapters/calendar-adapter.test.ts",
    "src/features/dashboard/rubrics/adapters/rubric-adapter.test.ts",
    "src/components/organisms/neon-kanban-board.test.tsx",
    "src/components/organisms/neon-top-bar.test.tsx",
    "src/components/organisms/neon-stats-grid.test.tsx",
    "src/components/organisms/neon-sidebar.test.tsx",
    "src/features/knowledge/adapters/document-adapter.test.ts",
    "src/features/blog/adapters/blog-post-adapter.test.ts"
  ],
  "ignorePatterns_comment": "Keep the mutation target narrow and exclude component-heavy test files from the Stryker sandbox to avoid slow, low-signal dry runs. Hook and API-client tests remain in scope for the mutated files."
}
