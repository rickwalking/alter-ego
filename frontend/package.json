{
  "name": "alter-ego-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --quiet && npm run lint:boundaries",
    "lint:all": "eslint --max-warnings=0 && npm run lint:boundaries",
    "lint:boundaries": "node scripts/check-feature-boundaries.mjs",
    "lint:changed": "node ../scripts/ci/eslint-changed.mjs",
    "boundaries:baseline": "node scripts/generate-feature-boundary-baseline.mjs",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:mutate": "stryker run",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "typecheck": "tsc --noEmit",
    "check:legacy": "node scripts/check-legacy-usage.mjs",
    "check:legacy-inventory": "node scripts/check-legacy-usage.mjs --inventory",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.10",
    "@radix-ui/react-dropdown-menu": "^2.1.10",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.10",
    "@radix-ui/react-select": "^2.2.2",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-tabs": "^1.1.7",
    "@radix-ui/react-tooltip": "^1.2.3",
    "@tanstack/react-query": "^5.74.0",
    "@tanstack/react-query-devtools": "^5.74.0",
    "@tiptap/pm": "^3.23.6",
    "@tiptap/react": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6",
    "class-variance-authority": "^0.7.1",
    "client-only": "^0.0.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.7.4",
    "jose": "^6.2.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.488.0",
    "next": "^16.2.6",
    "next-intl": "^4.9.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.55.0",
    "react-markdown": "^10.1.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.2.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@hookform/resolvers": "^5.0.1",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "^9.1.20",
    "@storybook/nextjs-vite": "^9.1.20",
    "@storybook/react": "^9.1.20",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@tailwindcss/postcss": "^4",
    "@tanstack/eslint-plugin-query": "^5.100.14",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.14.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "@vitejs/plugin-react": "^4.4.0",
    "@vitest/coverage-v8": "^4.1.8",
    "babel-plugin-react-compiler": "^19.0.0-beta-ebf51a3-20250411",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "eslint-plugin-react-hooks": "^6.0.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "lint-staged": "^15.5.1",
    "msw": "^2.7.4",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "storybook": "^9.1.20",
    "tailwindcss": "^4",
    "typescript": "^5",
    "typescript-eslint": "^8.60.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
