# ─── Environment ─────────────────────────────────────────────
# development | test | staging | production. Production-like values
# (staging/production) enable startup hardening: a durable carousel
# checkpointer (CAROUSEL_CHECKPOINT_BACKEND=postgres) and a configured
# default image-provider key are required at boot (fail-fast).
ENVIRONMENT=development

# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://rag_user:rag_password@localhost:5432/rag_db
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ─── Authentication ──────────────────────────────────────────
SECRET_KEY=                                   # REQUIRED: generate via `openssl rand -hex 32`
ANON_SECRET_KEY=                              # REQUIRED: generate via `openssl rand -hex 32`
ACCESS_TOKEN_EXPIRE_MINUTES=60
ANON_TOKEN_EXPIRE_MINUTES=60

# ─── AI Providers ────────────────────────────────────────────
OPENAI_API_KEY=                               # Optional: set to enable GPT features
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

ANTHROPIC_API_KEY=                            # Optional: set to enable Claude features
ANTHROPIC_MODEL=claude-sonnet-4-6

GEMINI_API_KEY=                               # Default image provider (IMAGE_MODEL_DEFAULT=gemini); REQUIRED in production-like ENVIRONMENT or startup fails (AE-0215)

# ─── Vector Store ────────────────────────────────────────────
PINECONE_API_KEY=                             # Optional: set to enable RAG features
PINECONE_INDEX_NAME=rag-index
PINECONE_ENVIRONMENT=us-east-1

# ─── LangSmith Observability ─────────────────────────────────
LANGSMITH_API_KEY=                            # Optional: set to enable LangSmith tracing
LANGSMITH_PROJECT=rag-backend
LANGSMITH_TRACING=false

# ─── LangFuse Observability ──────────────────────────────────
LANGFUSE_SECRET_KEY=                          # Optional: set to enable LangFuse tracing
LANGFUSE_PUBLIC_KEY=                          # Public key from LangFuse project settings
LANGFUSE_BASE_URL=http://localhost:3001       # Browser / local dev URL
LANGFUSE_HOST=http://langfuse:3000            # Docker internal URL (overrides BASE_URL in compose)

# ─── Server ──────────────────────────────────────────────────
DEBUG=false
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=*

# ─── Search ──────────────────────────────────────────────────
DEFAULT_SEARCH_ALPHA=0.5
DEFAULT_TOP_K=5
MAX_CHUNKS_PER_DOCUMENT=1000
MAX_UPLOAD_SIZE_MB=50

# ─── Carousel Generator ──────────────────────────────────────
CAROUSEL_OUTPUT_DIR=./output/carousels
# memory/disabled are non-durable and rejected when ENVIRONMENT is
# production-like. Prod MUST set CAROUSEL_CHECKPOINT_BACKEND=postgres plus
# CAROUSEL_CHECKPOINT_POSTGRES_URL so workflow state survives restarts (AE-0213).
CAROUSEL_CHECKPOINT_BACKEND=sqlite
CAROUSEL_CHECKPOINT_SQLITE_PATH=./output/carousel_checkpoints.sqlite
CAROUSEL_CHECKPOINT_POSTGRES_URL=
CAROUSEL_CHECKPOINT_TTL_DAYS=30
CAROUSEL_PUBLIC_BASE_URL=

# ─── Writing Style ───────────────────────────────────────────
WRITING_STYLE_URLS=
WRITING_STYLE_CACHE_DIR=./output/writing_style_cache

# ─── Meta / Instagram Publishing ─────────────────────────────
META_IG_ACCESS_TOKEN=
META_IG_USER_ID=

# ─── App Info ────────────────────────────────────────────────
APP_NAME=RAG Backend
APP_VERSION=0.1.0
