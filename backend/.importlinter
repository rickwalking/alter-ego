# GENERATED — do not edit ignore lists by hand.
# Regenerate: uv run python scripts/metrics/import_baseline.py --emit-importlinter \
#   > backend/.importlinter   (run from repo root)
# Static layer contracts below are hand-maintained; the per-contract
# ignore_imports blocks are the generated AE-0082 baseline exception
# list (existing violations grandfathered; any NEW pair breaks CI).

[importlinter]
root_package = rag_backend
include_external_packages = true

# Contract: Domain must not import application, infrastructure, or API
[importlinter:contract:domain-independence]
name = Domain layer must not depend on outer layers
type = forbidden
source_modules =
    rag_backend.domain
forbidden_modules =
    rag_backend.application
    rag_backend.infrastructure
    rag_backend.api

# Contract: Infrastructure must not import API
[importlinter:contract:infrastructure-independence]
name = Infrastructure layer must not depend on API
type = forbidden
source_modules =
    rag_backend.infrastructure
forbidden_modules =
    rag_backend.api

# Contract: Domain layer must be acyclic internally
[importlinter:contract:domain-acyclic]
name = Domain layer must have no internal import cycles
type = layers
containers = rag_backend.domain
layers =
    protocols
    models
    constants

# Contract: module internals are private (import via the facade only)
# AE-0081 §7c stub; real modules replace _template per §7a.
[importlinter:contract:template-public-facade]
name = _template internals are private (import via the facade only)
type = forbidden
source_modules =
    rag_backend.api
    rag_backend.application
    rag_backend.domain
    rag_backend.infrastructure
forbidden_modules =
    rag_backend.modules._template.domain
    rag_backend.modules._template.application
    rag_backend.modules._template.infrastructure
    rag_backend.modules._template.api
    rag_backend.modules._template.bootstrap
    rag_backend.modules._template.constants

