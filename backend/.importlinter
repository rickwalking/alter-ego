[importlinter]
root_package = rag_backend
include_external_packages = false

# Contract 1: Domain must not import application, infrastructure, or API
[importlinter:contract:domain-independence]
name = Domain layer must not depend on outer layers
type = forbidden
source_modules =
    rag_backend.domain
forbidden_modules =
    rag_backend.application
    rag_backend.infrastructure
    rag_backend.api

# Contract 2: Application must not import infrastructure or API
[importlinter:contract:application-independence]
name = Application layer must not depend on infrastructure or API
type = forbidden
source_modules =
    rag_backend.application
forbidden_modules =
    rag_backend.infrastructure
    rag_backend.api
# Logging is a cross-cutting concern; the application layer and agent
# orchestrators use the infrastructure logger via a thin wrapper. This
# is an accepted exception in Clean Architecture for observability.
ignore_imports =
    rag_backend.application.** -> rag_backend.infrastructure.logging
    rag_backend.application.** -> rag_backend.infrastructure.**
    rag_backend.application.** -> rag_backend.agents.**
    rag_backend.application.** -> rag_backend.api.**

# Contract 3: Infrastructure must not import API
[importlinter:contract:infrastructure-independence]
name = Infrastructure layer must not depend on API
type = forbidden
source_modules =
    rag_backend.infrastructure
forbidden_modules =
    rag_backend.api

# Contract 4: API may import all layers (top of the dependency chain)
# This is implicitly allowed by not having a contract against it.

# Contract 5: Domain layer must be acyclic internally
[importlinter:contract:domain-acyclic]
name = Domain layer must have no internal import cycles
type = layers
containers = rag_backend.domain
layers =
    protocols
    models
    constants
