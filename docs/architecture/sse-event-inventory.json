        "EVENT_TYPE_BLOGPOST_VERSION_RESTORED": "content.blogpost.version.restored",
        "EVENT_TYPE_BLOGPOST_AI_ACTION": "content.blogpost.ai.action",
        "EVENT_TYPE_NOTIFICATION_CREATED": "content.notification.created"
      }
    }
  },
  "frontend": {
    "src/constants/editorial-workflow.ts": {
