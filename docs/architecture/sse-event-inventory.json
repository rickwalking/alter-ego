        "SSE_EVENT_KEEPALIVE": "_keepalive"
      }
    },
    "domain/constants/chat_stream.py": {
      "layer": "domain",
      "constants": {
        "SSE_EVENT_TOKEN": "token",
        "SSE_EVENT_SOURCES": "sources",
        "SSE_EVENT_COMPLETE": "complete",
        "SSE_EVENT_ERROR": "error",
        "SSE_EVENT_TOOL_RESULT": "tool_result"
      }
    },
    "domain/constants/workflow_events.py": {
