# Root environment template for Docker Compose (copy to .env — never commit .env)
# Generate secrets with: openssl rand -hex 32

# ─── Application ───────────────────────────────────────────────
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=change-me
POSTGRES_DB=rag_db
SECRET_KEY=change-me-use-openssl-rand-hex-32
ANON_SECRET_KEY=change-me-use-openssl-rand-hex-32
ALLOWED_ORIGINS=http://localhost:3000

# ─── AI Providers (set in backend/.env for local dev) ────────
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# PINECONE_API_KEY=

# ─── Langfuse (self-hosted observability) ─────────────────────
# Required for Langfuse web/worker; set on host .env, not in git
LANGFUSE_NEXTAUTH_SECRET=generate-with-openssl-rand-hex-32
LANGFUSE_SALT=generate-with-openssl-rand-hex-32
LANGFUSE_ENCRYPTION_KEY=generate-with-openssl-rand-hex-32
LANGFUSE_CLICKHOUSE_PASSWORD=changeme

# Tracing keys — create in Langfuse UI → Project Settings → API Keys
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=http://localhost:3001
LANGFUSE_HOST=http://langfuse:3000

# Redis auth (AE-0302) — REQUIRED in production-like environments (Redis and
# the backend both fail closed without it). Shared by the backend, Langfuse,
# and langfuse-worker. Generate: openssl rand -hex 32
REDIS_PASSWORD=generate-with-openssl-rand-hex-32
