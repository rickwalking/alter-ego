#!/usr/bin/env sh
# commitlint and its config (frontend/.commitlintrc.json) both live under
# frontend/, so the @commitlint/config-conventional preset resolves from
# frontend/node_modules. Put the frontend bin dir on PATH and resolve the
# commit-message file to an absolute path before changing directory (AE-0168).
root="$(git rev-parse --show-toplevel)"
msg="$1"
case "$msg" in
  /*) ;;                 # already absolute
  *) msg="$root/$msg" ;; # relative to the repo root where git runs the hook
esac
[ -x "$root/frontend/node_modules/.bin/commitlint" ] || {
  echo "commit-msg: frontend deps not installed — skipping commitlint." >&2
  exit 0
}
export PATH="$root/frontend/node_modules/.bin:$PATH"
cd "$root/frontend" && commitlint --edit "$msg"
